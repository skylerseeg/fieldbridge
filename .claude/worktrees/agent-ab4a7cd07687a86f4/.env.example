# ==============================================================================
# FieldBridge — Environment Configuration
# VanCon Inc. | Copy this file to .env and fill in all values
# NEVER commit .env to git — it is listed in .gitignore
# ==============================================================================


# ------------------------------------------------------------------------------
# Microsoft Azure / M365  (Request 1 — Cyber Advisors)
# ------------------------------------------------------------------------------

# Found at: Azure Portal → Microsoft Entra ID → Overview → Tenant ID
AZURE_TENANT_ID=27c00eb3-08d1-4630-a0be-e2ae3bb5337c

# Found at: Azure Portal → Entra ID → App Registrations → FieldBridge → Overview → Application (client) ID
AZURE_CLIENT_ID=5946dc85-d0e1-4ba6-adf3-8ce8e34d5775

# Found at: App Registrations → FieldBridge → Certificates & secrets → New client secret → Value
# Copy immediately — value is hidden after you leave the page
AZURE_CLIENT_SECRET=

# Mailbox to scan for supplier/vendor emails (AP inbox)
AP_MAILBOX=ap@vanconinc.com

# How many days back to scan on first run
LOOKBACK_DAYS=365


# ------------------------------------------------------------------------------
# Vista ERP  (Request 2 — Trimble Data Xchange)
# ------------------------------------------------------------------------------

# Vista SQL Server — read-only service account (internal network / VPN required)
VISTA_SQL_HOST=
VISTA_SQL_PORT=1433
VISTA_SQL_DB=
VISTA_SQL_USER=
VISTA_SQL_PASSWORD=

# Trimble Data Xchange REST API — provided by your Trimble account rep
VISTA_API_BASE_URL=
VISTA_API_KEY=


# ------------------------------------------------------------------------------
# FieldBridge Postgres  (local dev default — change in production)
# ------------------------------------------------------------------------------

DATABASE_URL=postgresql://fieldbridge:password@localhost:5432/fieldbridge


# ------------------------------------------------------------------------------
# Anthropic Claude
# ------------------------------------------------------------------------------

# Get at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=


# ------------------------------------------------------------------------------
# Azure Blob Storage  (media library — v3 module, not needed for v1)
# ------------------------------------------------------------------------------

AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=fieldbridge-media


# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------

# Options: development | staging | production
ENVIRONMENT=development

# Generate a strong random key for production: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

OUTPUT_DIR=./output


# ------------------------------------------------------------------------------
# Frontend Auth (NextAuth.js + Microsoft Entra ID)
# These are read by the Next.js app in fieldbridge/frontend. Set them in Vercel
# Project → Settings → Environment Variables (Production + Preview).
# ------------------------------------------------------------------------------

# Public URL of the deployed site. In Vercel this must match the primary domain
# you visit (e.g. https://fieldbridge-repo.vercel.app). Required by NextAuth
# to build OAuth callback URLs.
NEXTAUTH_URL=https://fieldbridge-repo.vercel.app

# JWT signing secret for NextAuth. Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=

# Azure AD (Microsoft Entra) app registration used for user sign-in.
# App registration must have the redirect URI:
#   https://fieldbridge-repo.vercel.app/api/auth/callback/azure-ad
# Supported account types: "Accounts in this organizational directory only"
# (single tenant — the wedigutah.com tenant).
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# Email domain allowed to sign in. Users with addresses outside this domain
# are rejected after OAuth. Used by both server middleware and the login UI.
ALLOWED_EMAIL_DOMAIN=wedigutah.com
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=wedigutah.com
