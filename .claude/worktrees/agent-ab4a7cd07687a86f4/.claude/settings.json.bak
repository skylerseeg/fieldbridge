{
  "//": "FieldBridge shared Claude Code permission policy. Commit this file.",
  "//1": "FieldBridge is a multi-tenant SaaS wrapper around Trimble Viewpoint Vista ERP",
  "//2": "for heavy-civil contractors. Every paying tenant's Vista credentials flow through",
  "//3": "the SAME adapter code, so a bug or prompt-injection in the protected zones below",
  "//4": "has blast radius = every customer's production ERP. Deny rules reflect that.",
  "//5": "Per-developer auto-learned rules live in .claude/settings.local.json (gitignored).",
  "//6": "Deny always overrides allow. Ask sits in the middle for human-confirm cases.",

  "permissions": {
    "allow": [
      "//--- Read-only exploration -------------------------------------------",
      "//   Broad reads are safe because the deny list below blocks secrets.",
      "Read(**)",
      "Glob(**)",
      "Grep(**)",

      "//--- Routine edits: per-module backend surface + tests + frontend UI -",
      "//   fieldbridge/backend/app/modules/<module>/{schema,service,router}.py",
      "//   is the module-build contract. Tests mirror it. Agents edit these",
      "//   freely. Anything outside this surface falls through to deny/ask.",
      "Edit(fieldbridge/backend/app/modules/**)",
      "Write(fieldbridge/backend/app/modules/**)",
      "Edit(fieldbridge/backend/tests/**)",
      "Write(fieldbridge/backend/tests/**)",
      "Edit(fieldbridge/backend/app/api/v1/endpoints/**)",
      "Write(fieldbridge/backend/app/api/v1/endpoints/**)",
      "Edit(fieldbridge/backend/app/api/v1/__init__.py)",

      "//   Mart schema/ingest code. Per-module Excel mart adapters under",
      "//   services/excel_marts/<mart>/ are routine to extend. The shared",
      "//   _base.py helper is protected separately below.",
      "Edit(fieldbridge/backend/app/services/excel_marts/*/schema.py)",
      "Write(fieldbridge/backend/app/services/excel_marts/*/schema.py)",
      "Edit(fieldbridge/backend/app/services/excel_marts/*/ingest.py)",
      "Write(fieldbridge/backend/app/services/excel_marts/*/ingest.py)",
      "Edit(fieldbridge/backend/app/services/excel_marts/*/__init__.py)",
      "Write(fieldbridge/backend/app/services/excel_marts/*/__init__.py)",

      "//   Non-Vista services: AI agents, proposal engine, bid intelligence,",
      "//   media library, project memory, metering. These may call Vista via",
      "//   the vista_sync adapter (denied below) but don't OWN Vista plumbing.",
      "Edit(fieldbridge/backend/app/services/bid_intelligence/**)",
      "Write(fieldbridge/backend/app/services/bid_intelligence/**)",
      "Edit(fieldbridge/backend/app/services/proposal_engine/**)",
      "Write(fieldbridge/backend/app/services/proposal_engine/**)",
      "Edit(fieldbridge/backend/app/services/media_library/**)",
      "Write(fieldbridge/backend/app/services/media_library/**)",
      "Edit(fieldbridge/backend/app/services/project_memory/**)",
      "Write(fieldbridge/backend/app/services/project_memory/**)",
      "Edit(fieldbridge/backend/app/services/metering/**)",
      "Write(fieldbridge/backend/app/services/metering/**)",
      "Edit(fieldbridge/backend/app/services/email_bridge/**)",
      "Write(fieldbridge/backend/app/services/email_bridge/**)",
      "Edit(fieldbridge/backend/app/services/design_automation/**)",
      "Write(fieldbridge/backend/app/services/design_automation/**)",

      "//   Claude agents — self-contained per-directory.",
      "Edit(fieldbridge/agents/**)",
      "Write(fieldbridge/agents/**)",

      "//   Workers (cron jobs, n8n flow JSON).",
      "Edit(fieldbridge/workers/**)",
      "Write(fieldbridge/workers/**)",

      "//   Frontend UI layer. Vite + React Router + TanStack Query + Tailwind",
      "//   + shadcn/ui, hand-rolled primitives under src/components/ui/.",
      "//   The Next.js tree was retired in the Commit-5 swap; frontend-v2/",
      "//   was moved into place as the new frontend/.",
      "Edit(fieldbridge/frontend/src/**)",
      "Write(fieldbridge/frontend/src/**)",
      "Edit(fieldbridge/frontend/public/**)",
      "Write(fieldbridge/frontend/public/**)",
      "Edit(fieldbridge/frontend/index.html)",
      "Edit(fieldbridge/frontend/tailwind.config.*)",
      "Edit(fieldbridge/frontend/postcss.config.*)",
      "Edit(fieldbridge/frontend/vite.config.ts)",
      "Edit(fieldbridge/frontend/tsconfig.json)",
      "Edit(fieldbridge/frontend/tsconfig.node.json)",
      "Edit(fieldbridge/frontend/components.json)",
      "Edit(fieldbridge/frontend/vercel.json)",

      "//   Docs and CLAUDE.md — freely editable.",
      "Edit(fieldbridge/docs/**)",
      "Write(fieldbridge/docs/**)",
      "Edit(CLAUDE.md)",
      "Edit(fieldbridge/README.md)",
      "Edit(fieldbridge/backend/README.md)",
      "Edit(fieldbridge/frontend/README.md)",

      "//   Non-customer SaaS tooling (VANCON-internal prospect work).",
      "Edit(fieldbridge/saas/**)",
      "Write(fieldbridge/saas/**)",

      "//--- Routine commands: typecheck, build, lint, test ------------------",
      "//   Anything that does NOT mutate dependencies, the DB, or git state.",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run start)",
      "Bash(npm run dev:local)",
      "Bash(npm list*)",
      "Bash(npm outdated*)",
      "Bash(npx tsc --noEmit*)",
      "Bash(npx vite build*)",
      "Bash(npx vite preview*)",
      "Bash(npm run typecheck)",
      "Bash(npm run preview)",

      "Bash(pytest*)",
      "Bash(python -m pytest*)",
      "Bash(ruff*)",
      "Bash(black*)",
      "Bash(mypy*)",

      "//   Read-only git. Destructive ops are denied below.",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git rev-parse*)",
      "Bash(git blame*)",
      "Bash(git remote -v)",
      "Bash(git stash list)",

      "//   Safe commits on the designated dev branch are allowed; push is not.",
      "Bash(git add *)",
      "Bash(git commit *)",

      "//   Read-only filesystem probes.",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(find*)",
      "Bash(wc*)",
      "Bash(file*)",
      "Bash(stat*)",

      "//--- Doc lookups -----------------------------------------------------",
      "WebSearch",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:fastapi.tiangolo.com)",
      "WebFetch(domain:docs.pydantic.dev)",
      "WebFetch(domain:docs.sqlalchemy.org)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:typescriptlang.org)"
    ],

    "deny": [
      "//====================================================================",
      "// SECRETS — never read, never write.",
      "//====================================================================",
      "// .env holds per-tenant Vista SQL credentials, Vista REST API keys,",
      "// Azure blob keys, SMTP creds, and the JWT signing secret. One leak",
      "// via an accidental commit or a prompt-injected tool call compromises",
      "// every onboarded tenant's production ERP. No exceptions.",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Read(**/secrets/**)",
      "Edit(**/secrets/**)",
      "Write(**/secrets/**)",
      "Read(**/credentials/**)",
      "Edit(**/credentials/**)",
      "Write(**/credentials/**)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Edit(**/*.key)",
      "Edit(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*.pem)",

      "//====================================================================",
      "// VISTA ADAPTER — resale-risk code.",
      "//====================================================================",
      "// Every paying customer's Vista ERP is reached through the SAME",
      "// adapter with THEIR credentials. A SQL injection, a missing HQCo",
      "// filter, or a misdirected REST POST hits every tenant at once.",
      "// Changes here require human review. docs/vista_schemas/ is the",
      "// Vista table reference — protected because agents sometimes",
      "// 'correct' it to match hallucinated schema.",
      "Edit(fieldbridge/backend/app/core/tenant.py)",
      "Write(fieldbridge/backend/app/core/tenant.py)",
      "Edit(fieldbridge/backend/app/services/vista_sync/**)",
      "Write(fieldbridge/backend/app/services/vista_sync/**)",
      "Edit(fieldbridge/data/vista_schemas/**)",
      "Write(fieldbridge/data/vista_schemas/**)",

      "//====================================================================",
      "// MULTI-TENANT FOUNDATION — data-leak risk at scale.",
      "//====================================================================",
      "// Auth dependencies, tenant resolution, role gates, and the",
      "// Tenant/User SQLAlchemy models together define the 'can user A",
      "// from tenant X see anything owned by tenant Y' boundary. Breaking",
      "// WHERE tenant_id = :tenant_id once here breaks it for every",
      "// module that inherits the dependency. config/database are denied",
      "// because they hold engine/session factories and secret plumbing.",
      "Edit(fieldbridge/backend/app/core/auth.py)",
      "Write(fieldbridge/backend/app/core/auth.py)",
      "Edit(fieldbridge/backend/app/models/tenant.py)",
      "Write(fieldbridge/backend/app/models/tenant.py)",
      "Edit(fieldbridge/backend/app/models/user.py)",
      "Write(fieldbridge/backend/app/models/user.py)",
      "Edit(fieldbridge/backend/app/core/config.py)",
      "Write(fieldbridge/backend/app/core/config.py)",
      "Edit(fieldbridge/backend/app/core/database.py)",
      "Write(fieldbridge/backend/app/core/database.py)",

      "//====================================================================",
      "// SOURCE DATA — only ground truth until Vista API lights up.",
      "//====================================================================",
      "// fieldbridge/data/ holds the CSV/Excel exports that feed every",
      "// mart (ingested by services/excel_marts/*/ingest.py). An agent",
      "// that 'fixes' a row or renames a column silently changes every",
      "// downstream KPI tile. Read-heavy, write-rare, human-gated writes.",
      "Edit(fieldbridge/data/**)",
      "Write(fieldbridge/data/**)",

      "//====================================================================",
      "// DB BOOTSTRAP / DDL / SEED / MIGRATIONS.",
      "//====================================================================",
      "// These files shape the schema and seed the VanCon reference tenant.",
      "// A bad edit wipes tables, double-seeds tenants, or breaks the test",
      "// fixture path. Migrations (if/when we adopt Alembic or Prisma) are",
      "// also protected; a silent migration change corrupts prod on deploy.",
      "Edit(fieldbridge/backend/scripts/create_mart_tables.py)",
      "Write(fieldbridge/backend/scripts/create_mart_tables.py)",
      "Edit(fieldbridge/backend/scripts/run_ingest.py)",
      "Write(fieldbridge/backend/scripts/run_ingest.py)",
      "Edit(fieldbridge/backend/app/core/seed.py)",
      "Write(fieldbridge/backend/app/core/seed.py)",
      "Edit(fieldbridge/backend/app/core/ingest.py)",
      "Write(fieldbridge/backend/app/core/ingest.py)",
      "Edit(fieldbridge/backend/app/services/excel_marts/_base.py)",
      "Write(fieldbridge/backend/app/services/excel_marts/_base.py)",
      "Edit(fieldbridge/backend/app/services/excel_marts/__init__.py)",
      "Write(fieldbridge/backend/app/services/excel_marts/__init__.py)",
      "Edit(fieldbridge/backend/app/services/excel_marts/_fte_shared.py)",
      "Write(fieldbridge/backend/app/services/excel_marts/_fte_shared.py)",
      "Edit(**/migrations/**)",
      "Write(**/migrations/**)",
      "Edit(**/alembic/versions/**)",
      "Write(**/alembic/versions/**)",
      "Bash(alembic upgrade*)",
      "Bash(alembic downgrade*)",
      "Bash(alembic revision*)",
      "Bash(alembic stamp*)",
      "Bash(prisma migrate*)",
      "Bash(prisma db push*)",
      "Bash(prisma db seed*)",
      "Bash(dropdb*)",
      "Bash(createdb*)",

      "//====================================================================",
      "// DESTRUCTIVE SHELL / GIT — irreversible operations.",
      "//====================================================================",
      "Bash(rm -rf*)",
      "Bash(rm -r *)",
      "Bash(sudo rm*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fx*)",
      "Bash(git checkout --force*)",
      "Bash(git checkout -f*)",
      "Bash(git checkout -- *)",
      "Bash(git restore --source*)",
      "Bash(git branch -D*)",
      "Bash(git rebase*)",
      "Bash(git filter-branch*)",
      "Bash(git update-ref -d*)",

      "//====================================================================",
      "// DEPENDENCY CHURN — supply-chain risk surface.",
      "//====================================================================",
      "// Agents silently adding packages is a classic typosquat vector.",
      "// Require a human to approve each add/remove.",
      "Bash(npm install *)",
      "Bash(npm i *)",
      "Bash(npm uninstall *)",
      "Bash(npm remove *)",
      "Bash(npm audit fix*)",
      "Bash(yarn add *)",
      "Bash(yarn remove *)",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)",
      "Bash(pip install *)",
      "Bash(pip uninstall *)",
      "Bash(pip3 install *)",
      "Bash(pip3 uninstall *)",
      "Bash(poetry add *)",
      "Bash(poetry remove *)",

      "//====================================================================",
      "// NETWORK EXFILTRATION — block arbitrary outbound HTTP.",
      "//====================================================================",
      "// Doc lookups go through WebFetch with the whitelisted domains in",
      "// the allow list. curl/wget to ad-hoc URLs (including shell-in-the-",
      "// middle attacks that pipe remote content into bash) are denied.",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(*| bash*)",
      "Bash(*| sh*)"
    ]
  }
}
