# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
*.egg-info/
.coverage

# Environment
.env
.env.local
*.local

# Vercel
.vercel/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Windows / WSL artifacts (NTFS alternate data streams from Windows downloads)
*:Zone.Identifier
*.crdownload
*.crdownload:*

# Binaries / installers — these belong in ~/Downloads, not the repo
# (Caught a 473 MB SSMS-Setup-ENU.exe trying to sneak in via docs/)
*.exe
*.msi
*.dmg
*.iso

# Logs
*.log

# Local-only runtime artifacts (ingest DBs, scratch outputs, etc.)
# Anything that gets regenerated by `make ingest`, dev scripts, or local
# experimentation belongs under .local/, NOT in the tracked tree.
.local/
*.db
*.sqlite
*.sqlite3
*.sqlite-journal
*.sqlite3-journal

# Scratch / throwaway debug scripts
# Anything dropped under scripts/scratch/ stays local-only (README excepted),
# as does anything matching *.scratch.*
scripts/scratch/*
!scripts/scratch/README.md
*.scratch.py
*.scratch.ts
*.scratch.js
*.scratch.sh
