# FieldBridge frontend (Vite) — example env.
# Copy to .env.local and fill in real values.
#
# The Vite dev server also reads ../fieldbridge/.env via the repo-root
# env-loading convention (see vite.config.ts), so Vista/Azure credentials
# stay out of the frontend's .env.local.

# URL the browser uses to reach the FastAPI backend in production builds.
# In dev, requests to /api/* are proxied via vite.config.ts (see
# VITE_API_PROXY_TARGET below), so you can leave this empty.
VITE_API_URL=

# Dev-only: where the Vite dev proxy forwards /api/* requests.
# Default http://localhost:8000.
VITE_API_PROXY_TARGET=http://localhost:8000

# Microsoft 365 SSO (Commit 3 wiring). Leave empty for Commit 1/2.
VITE_M365_TENANT_ID=
VITE_M365_CLIENT_ID=
VITE_M365_REDIRECT_URI=http://localhost:5173/auth/callback

# Domain allowlist for email/password login (Commit 4).
# Comma-separated. Leave empty to allow all.
VITE_ALLOWED_EMAIL_DOMAINS=
